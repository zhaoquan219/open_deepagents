APP_NAME=DeepAgents Agent Platform Backend
API_PREFIX=/api
DATABASE_URL=sqlite+pysqlite:///./data/backend.db
# For MySQL deployment:
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/deepagents_platform
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=change-me-too
ADMIN_TOKEN_EXPIRE_MINUTES=720
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
UPLOAD_STORAGE_DIR=./data/uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# Default model used when CUSTOM_API_* is not fully configured.
DEEPAGENTS_MODEL=openai:gpt-5.4
DEEPAGENTS_AGENT_NAME=deepagents-web
DEEPAGENTS_DEBUG=false
DEEPAGENTS_TOOL_SPECS=extensions/tools/echo_tool.py:TOOLS
DEEPAGENTS_MIDDLEWARE_SPECS=extensions/middleware/audit_middleware.py:MIDDLEWARE
DEEPAGENTS_SKILLS=extensions/skills
DEEPAGENTS_MEMORY=

# Default sandbox permissions are enforced in code:
# read-only access to backend/data and backend/extensions/skills
DEEPAGENTS_SANDBOX_KIND=state
DEEPAGENTS_SANDBOX_ROOT_DIR=./data/sandbox
DEEPAGENTS_SANDBOX_VIRTUAL_MODE=false
DEEPAGENTS_SANDBOX_TIMEOUT=120
DEEPAGENTS_SANDBOX_MAX_OUTPUT_BYTES=100000
DEEPAGENTS_SANDBOX_INHERIT_ENV=false
DEEPAGENTS_SANDBOX_BACKEND_SPEC=

# Optional:
# DEEPAGENTS_MEMORY=/absolute/path/to/project-memory.md

# Optional OpenAI-compatible custom endpoint:
# If CUSTOM_API_KEY, CUSTOM_API_URL, and CUSTOM_API_MODEL are all set,
# the backend uses that custom endpoint and CUSTOM_API_MODEL takes precedence
# over DEEPAGENTS_MODEL.
# CUSTOM_API_KEY=your-api-key
# CUSTOM_API_URL=https://your-endpoint.example.com/v1
# CUSTOM_API_MODEL=glm-4.5
# Optional. Leave empty to let the provider default apply.
# When unset or empty, the backend does not send a temperature field.
# CUSTOM_API_TEMPERATURE=
# Optional. Recommended format: JSON object string.
# CUSTOM_API_DEFAULT_HEADERS={"HTTP-Referer":"https://app.example.com","X-Title":"open_deepagents"}
# Backward-compatible fallback:
# CUSTOM_API_DEFAULT_HEADERS=HTTP-Referer=https://app.example.com,X-Title=open_deepagents
