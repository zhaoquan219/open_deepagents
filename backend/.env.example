# =============================================================================
# open_deepagents backend environment
# Copy this file to backend/.env and replace secrets before deployment.
# =============================================================================

# Application
APP_NAME=DeepAgents Agent Platform Backend
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database
DATABASE_URL=sqlite+pysqlite:///./data/backend.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/deepagents_platform

# Administrator access
ADMIN_AUTH_ENABLED=true
# Set ADMIN_AUTH_ENABLED=false for trusted local deployments that should open
# directly without the login screen.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=change-me-too
ADMIN_TOKEN_EXPIRE_MINUTES=720

# Uploads
UPLOAD_STORAGE_DIR=./data/uploads
MAX_UPLOAD_SIZE_BYTES=100000000

# DeepAgents model
DEEPAGENTS_MODEL=openai:gpt-5.4
DEEPAGENTS_AGENT_NAME=deepagents-web
DEEPAGENTS_DEBUG=false

# DeepAgents extension entrypoints
DEEPAGENTS_TOOL_SPECS=extensions.tools:TOOLS
DEEPAGENTS_MIDDLEWARE_SPECS=extensions.middleware:MIDDLEWARE
DEEPAGENTS_RUN_INPUT_HOOK_SPECS=extensions.runtime_hooks:RUN_INPUT_HOOKS
DEEPAGENTS_UPLOAD_HOOK_SPECS=extensions.runtime_hooks:UPLOAD_HOOKS
DEEPAGENTS_SKILLS=extensions/skills
DEEPAGENTS_MEMORY=

# DeepAgents built-in tool filters
# Built-in tool names:
# write_todos, ls, read_file, write_file, edit_file, glob, grep, execute, task
# The default keeps read/search/task tools and disables host execution plus writes.
DEEPAGENTS_BUILTIN_TOOLS=write_todos,ls,read_file,glob,grep,task
DEEPAGENTS_DISABLED_BUILTIN_TOOLS=execute,write_file,edit_file

# Sandbox backend
# See ../docs/sandbox.md for backend kinds, path behavior, and safety notes.
DEEPAGENTS_SANDBOX_KIND=state
DEEPAGENTS_SANDBOX_ROOT_DIR=./data
DEEPAGENTS_SANDBOX_VIRTUAL_MODE=false
DEEPAGENTS_SANDBOX_TIMEOUT=120
DEEPAGENTS_SANDBOX_MAX_OUTPUT_BYTES=100000
DEEPAGENTS_SANDBOX_INHERIT_ENV=false
DEEPAGENTS_SANDBOX_BACKEND_SPEC=

# Optional OpenAI-compatible custom endpoint
CUSTOM_API_KEY=
CUSTOM_API_URL=
CUSTOM_API_MODEL=
# Leave empty to let the provider default apply.
CUSTOM_API_TEMPERATURE=
# JSON object string, for example:
# CUSTOM_API_DEFAULT_HEADERS={"HTTP-Referer":"https://app.example.com","X-Title":"open_deepagents"}
CUSTOM_API_DEFAULT_HEADERS=
